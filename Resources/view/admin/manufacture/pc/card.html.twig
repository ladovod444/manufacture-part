<tr class="vertical-middle">


    <td class="text-nowrap">
        {# Пользовательское меню #}
        {{ include(_self|replace({ "card.html.twig": "_usecase.html.twig" })) }}
    </td>
    <td class="text-center text-nowrap">
        {{ item.part_date|date('d.m.Y H:i') }}
    </td>

    <td class="text-center">

        <span
                role="tooltip"
                data-bs-toggle="tooltip"
                data-bs-placement="bottom"
                data-bs-delay='{"show":600,"hide":100}'
                title='QR производственной партии'
        >

            <a href="{{ path('manufacture-part:admin.qrcode', { id : item.id, print: true }) }}"
               class="btn btn-sm btn-link disabled icon prnt"
               data-bs-toggle="modal"
               data-bs-target="#modal"
               style="width: 55px; height: 55px;"
            >
                    <svg
                            xmlns="http://www.w3.org/2000/svg" width="45" height="45" fill="currentColor"
                            class="bi bi-qr-code" viewBox="0 0 16 16"><path d="M2 2h2v2H2V2Z"></path><path
                                d="M6 0v6H0V0h6ZM5 1H1v4h4V1ZM4 12H2v2h2v-2Z"></path><path
                                d="M6 10v6H0v-6h6Zm-5 1v4h4v-4H1Zm11-9h2v2h-2V2Z"></path><path
                                d="M10 0v6h6V0h-6Zm5 1v4h-4V1h4ZM8 1V0h1v2H8v2H7V1h1Zm0 5V4h1v2H8ZM6 8V7h1V6h1v2h1V7h5v1h-4v1H7V8H6Zm0 0v1H2V8H1v1H0V7h3v1h3Zm10 1h-1V7h1v2Zm-1 0h-1v2h2v-1h-1V9Zm-4 0h2v1h-1v1h-1V9Zm2 3v-1h-1v1h-1v1H9v1h3v-2h1Zm0 0h3v1h-2v1h-1v-2Zm-4-1v1h1v-2H7v1h2Z"></path><path
                                d="M7 12h1v3h4v1H7v-4Zm9 2v2h-3v-1h2v-1h1Z"></path>
                    </svg>
                </a>


            </span>
    </td>
    <td class="w-100">
        <a href="{{ path('manufacture-part:admin.products.index', { id: item.id }) }}"
           class="fw-bolder mb-1 text-decoration-none product-name">
            {{ item.number }}
        </a>

        {% if item.category_name %}
            <div>
                <small class="opacity-50 fw-normal">Категория:</small> &nbsp; <strong>{{ item.category_name }}</strong>
            </div>
        {% endif %}

        <div>
            <small class="opacity-50 fw-normal">Производство:</small> &nbsp; <strong>{{ item.action_name }}</strong>
        </div>

        <div>
            <small class="opacity-50 fw-normal">Ответственный:</small> &nbsp; <strong> {{ item.users_profile_username }}
        </div>
    </td>

    <td class="text-center">
        {{ item.complete ? item.complete|trans({}, 'manufacture.complete') : 'Ничего не делать' }}
    </td>
    <td class="text-center">
        {{ manufacture_status(item.status) }}
    </td>

    <td class="text-center">

        {% if item.part_working_uid %}
            <h6 class="lh-normal m-0"><span class="badge text-bg-warning text-dark">{{ item.part_working }}</span></h6>
        {% else %}

            {% if item.status ==  'completed' %}
                <h6 class="lh-normal m-0"><span class="badge text-bg-success">Выполнено</span></h6>
            {% elseif item.status ==  'closed' %}
                <h6 class="lh-normal m-0"><span class="badge bg-light text-dark shadow">Выполнено</span></h6>
            {% elseif item.status ==  'defect' %}
                <h6 class="lh-normal m-0"><span class="badge bg-light text-dark shadow">Производство</span></h6>
            {% else %}
                <h6 class="lh-normal m-0"><span class="badge text-bg-secondary">Новая</span></h6>
            {% endif %}

        {% endif %}


        {# {% if item.part_working_uid == '0189a177-a104-7cf6-ac68-00b5e8c56137' %}
            <h6 class="lh-normal m-0"><span class="badge text-bg-secondary">Новая</span></h6>
        {% elseif item.part_working_uid == '01897e7c-3e0d-7350-90ba-bccaa2cf282a' %}
            <h6 class="lh-normal m-0"><span class="badge text-bg-secondary">Завершена</span></h6>
        {% else %}
            <h6 class="lh-normal m-0"><span class="badge text-bg-secondary">{{ item.part_working }}</span></h6>
        {% endif %} #}
    </td>

    <td class="text-center">
        {{ item.quantity }}
    </td>

    {# Печать товаров производственной партии #}
    <td class="text-nowrap">
        <div class="d-flex gap-2">

            <a href="{{ path('manufacture-part:admin.products.index', { id: item.id, print: 1 }) }}"
               class="btn btn-light small prnt"
               data-bs-toggle="modal"
               data-bs-target="#modal"
               title="Печать товаров партии">

                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                     class="bi bi-printer-fill"
                     viewBox="0 0 16 16">
                    <path d="M5 1a2 2 0 0 0-2 2v1h10V3a2 2 0 0 0-2-2H5zm6 8H5a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1z"/>
                    <path d="M0 7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-1v-2a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2H2a2 2 0 0 1-2-2V7zm2.5 1a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1z"/>
                </svg>

                <div class="small">Печать</div>
            </a>


            {# FBS Wildberries #}
            {# @var TypeDeliveryFbsWildberries BaksDev\Wildberries\Orders\Type\DeliveryType\TypeDeliveryFbsWildberries #}

            {% if
                constant('BaksDev\\Wildberries\\Orders\\Type\\DeliveryType\\TypeDeliveryFbsWildberries::TYPE') is defined
                and constant('BaksDev\\Wildberries\\Orders\\Type\\DeliveryType\\TypeDeliveryFbsWildberries::TYPE') == item.complete %}


                <a href="{{ path('wildberries-package:admin.package.index') }}"
                   class="btn btn-light small"
                   role="tooltip"
                   data-bs-toggle="tooltip"
                   data-bs-placement="bottom"
                   data-bs-delay='{"show":600,"hide":100}'
                   title="Упаковка аказов Wildberries FBS"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                         class="bi bi-box-seam" viewBox="0 0 16 16">
                        <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923zM7.443.184a1.5 1.5 0 0 1 1.114 0l7.129 2.852A.5.5 0 0 1 16 3.5v8.662a1 1 0 0 1-.629.928l-7.185 2.874a.5.5 0 0 1-.372 0L.63 13.09a1 1 0 0 1-.63-.928V3.5a.5.5 0 0 1 .314-.464z"/>
                    </svg>

                    <div class="small">Упаковка</div>
                </a>

                <a href="{{ path('wildberries-manufacture:admin.fbs') }}"
                   class="btn btn-sm btn-light small"
                   role="tooltip"
                   data-bs-toggle="tooltip"
                   data-bs-placement="bottom"
                   data-bs-delay='{"show":600,"hide":100}'
                   title="Производство Wildberries FBS"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                         class="bi bi-boxes"
                         viewBox="0 0 16 16">
                        <path d="M7.752.066a.5.5 0 0 1 .496 0l3.75 2.143a.5.5 0 0 1 .252.434v3.995l3.498 2A.5.5 0 0 1 16 9.07v4.286a.5.5 0 0 1-.252.434l-3.75 2.143a.5.5 0 0 1-.496 0l-3.502-2-3.502 2.001a.5.5 0 0 1-.496 0l-3.75-2.143A.5.5 0 0 1 0 13.357V9.071a.5.5 0 0 1 .252-.434L3.75 6.638V2.643a.5.5 0 0 1 .252-.434L7.752.066ZM4.25 7.504 1.508 9.071l2.742 1.567 2.742-1.567L4.25 7.504ZM7.5 9.933l-2.75 1.571v3.134l2.75-1.571V9.933Zm1 3.134 2.75 1.571v-3.134L8.5 9.933v3.134Zm.508-3.996 2.742 1.567 2.742-1.567-2.742-1.567-2.742 1.567Zm2.242-2.433V3.504L8.5 5.076V8.21l2.75-1.572ZM7.5 8.21V5.076L4.75 3.504v3.134L7.5 8.21ZM5.258 2.643 8 4.21l2.742-1.567L8 1.076 5.258 2.643ZM15 9.933l-2.75 1.571v3.134L15 13.067V9.933ZM3.75 14.638v-3.134L1 9.933v3.134l2.75 1.571Z"/>
                    </svg>

                    <div class="small">FBS</div>
                </a>

            {% endif %}


            {# FBS Ozon #}
            {# @var TypeDeliveryFbsOzon BaksDev\Ozon\Orders\Type\DeliveryType\TypeDeliveryFbsOzon #}

            {% if
                constant('BaksDev\\Ozon\\Orders\\Type\\DeliveryType\\TypeDeliveryFbsOzon::TYPE') is defined
                and constant('BaksDev\\Ozon\\Orders\\Type\\DeliveryType\\TypeDeliveryFbsOzon::TYPE') == item.complete %}


                <a href="{{ path('ozon-package:admin.package.index') }}"
                   class="btn btn-light small"
                   role="tooltip"
                   data-bs-toggle="tooltip"
                   data-bs-placement="bottom"
                   data-bs-delay='{"show":600,"hide":100}'
                   title="Упаковка аказов Ozon FBS"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                         class="bi bi-box-seam" viewBox="0 0 16 16">
                        <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923zM7.443.184a1.5 1.5 0 0 1 1.114 0l7.129 2.852A.5.5 0 0 1 16 3.5v8.662a1 1 0 0 1-.629.928l-7.185 2.874a.5.5 0 0 1-.372 0L.63 13.09a1 1 0 0 1-.63-.928V3.5a.5.5 0 0 1 .314-.464z"/>
                    </svg>

                    <div class="small">Упаковка</div>
                </a>

                <a href="{{ path('ozon-manufacture:admin.fbs') }}"
                   class="btn btn-sm btn-light small"
                   role="tooltip"
                   data-bs-toggle="tooltip"
                   data-bs-placement="bottom"
                   data-bs-delay='{"show":600,"hide":100}'
                   title="Производство Ozon FBS"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                         class="bi bi-boxes"
                         viewBox="0 0 16 16">
                        <path d="M7.752.066a.5.5 0 0 1 .496 0l3.75 2.143a.5.5 0 0 1 .252.434v3.995l3.498 2A.5.5 0 0 1 16 9.07v4.286a.5.5 0 0 1-.252.434l-3.75 2.143a.5.5 0 0 1-.496 0l-3.502-2-3.502 2.001a.5.5 0 0 1-.496 0l-3.75-2.143A.5.5 0 0 1 0 13.357V9.071a.5.5 0 0 1 .252-.434L3.75 6.638V2.643a.5.5 0 0 1 .252-.434L7.752.066ZM4.25 7.504 1.508 9.071l2.742 1.567 2.742-1.567L4.25 7.504ZM7.5 9.933l-2.75 1.571v3.134l2.75-1.571V9.933Zm1 3.134 2.75 1.571v-3.134L8.5 9.933v3.134Zm.508-3.996 2.742 1.567 2.742-1.567-2.742-1.567-2.742 1.567Zm2.242-2.433V3.504L8.5 5.076V8.21l2.75-1.572ZM7.5 8.21V5.076L4.75 3.504v3.134L7.5 8.21ZM5.258 2.643 8 4.21l2.742-1.567L8 1.076 5.258 2.643ZM15 9.933l-2.75 1.571v3.134L15 13.067V9.933ZM3.75 14.638v-3.134L1 9.933v3.134l2.75 1.571Z"/>
                    </svg>

                    <div class="small">FBS</div>
                </a>

            {% endif %}


        </div>

    </td>

</tr>
